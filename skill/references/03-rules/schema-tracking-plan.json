{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/haiqigeng/ga4-tracking-plan/schema/schema-tracking-plan.json",
  "title": "GA4 tracking plan contract",
  "description": "Canonical GA4-only structure for analyst-readable, implementation-ready tracking plans.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "execution_context",
    "document",
    "measurement_brief",
    "measurement_strategy",
    "website_coverage_map",
    "user_context",
    "events",
    "parameters",
    "screenshot_capture",
    "screenshot_evidence",
    "not_tracked",
    "assumptions",
    "documentation_sources_checked"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]{2,80}$"
    },
    "execution_context": {
      "$ref": "#/$defs/executionContext"
    },
    "document": {
      "$ref": "#/$defs/document"
    },
    "measurement_brief": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/measurementBrief"
      }
    },
    "measurement_strategy": {
      "$ref": "#/$defs/measurementStrategy"
    },
    "website_coverage_map": {
      "$ref": "#/$defs/websiteCoverageMap"
    },
    "user_context": {
      "$ref": "#/$defs/userContext"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "screenshot_capture": {
      "$ref": "#/$defs/screenshotCapture"
    },
    "not_tracked": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/notTracked"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "documentation_sources_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/documentationSource"
      }
    },
    "screenshot_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/screenshotEvidence"
      }
    }
  },
  "$defs": {
    "executionContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_mode",
        "mode_reason",
        "input_artifact_inventory",
        "template_policy"
      ],
      "properties": {
        "execution_mode": {
          "enum": [
            "client_template_adaptation",
            "greenfield_best_practice",
            "existing_plan_review",
            "event_recommendation",
            "template_only"
          ]
        },
        "mode_reason": {
          "type": "string",
          "minLength": 1
        },
        "input_artifact_inventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inputArtifact"
          }
        },
        "template_policy": {
          "$ref": "#/$defs/templatePolicy"
        },
        "template_diff_summary": {
          "$ref": "#/$defs/templateDiffSummary"
        }
      }
    },
    "inputArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_type",
        "artifact_ref",
        "role",
        "template_relevance",
        "confidentiality_status"
      ],
      "properties": {
        "artifact_type": {
          "enum": [
            "website_url",
            "sitemap",
            "robots_txt",
            "client_tracking_plan",
            "tracking_plan_dev_doc",
            "tracking_plan_review",
            "event_inventory",
            "template_workbook",
            "screenshots",
            "user_brief",
            "analytics_export",
            "search_console_export",
            "site_discovery_json",
            "other"
          ]
        },
        "artifact_ref": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "template_relevance": {
          "enum": [
            "source_template",
            "client_criteria",
            "site_discovery",
            "evidence",
            "not_template"
          ]
        },
        "confidentiality_status": {
          "enum": [
            "generic",
            "client_provided",
            "public_url",
            "anonymized",
            "unknown"
          ]
        }
      }
    },
    "templatePolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "template_source",
        "preservation_requirements",
        "allowed_changes",
        "template_diff_required"
      ],
      "properties": {
        "mode": {
          "enum": [
            "strict_client_template",
            "default_skill_template",
            "hybrid_preserve_client_structure",
            "review_only",
            "not_applicable"
          ]
        },
        "template_source": {
          "type": "string",
          "minLength": 1
        },
        "preservation_requirements": {
          "$ref": "#/$defs/stringArray"
        },
        "allowed_changes": {
          "$ref": "#/$defs/stringArray"
        },
        "template_diff_required": {
          "type": "boolean"
        }
      }
    },
    "templateDiffSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "summary"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_needed",
            "not_started",
            "completed",
            "blocked"
          ]
        },
        "summary": {
          "type": "string"
        },
        "columns_added": {
          "$ref": "#/$defs/stringArray"
        },
        "columns_removed": {
          "$ref": "#/$defs/stringArray"
        },
        "style_or_structure_changes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "version",
        "owner",
        "publish_date"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "publish_date": {
          "type": "string",
          "minLength": 1,
          "description": "Publication date in YYYY-MM-DD format, or TBD while the plan remains unpublished."
        }
      }
    },
    "measurementBrief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journey_id",
        "journey_name",
        "scope",
        "url_or_route",
        "page_type",
        "expected_user_actions",
        "business_goal",
        "analysis_needs",
        "success_signals",
        "data_available",
        "implementation_context",
        "priority",
        "open_questions"
      ],
      "properties": {
        "journey_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_\\-]{2,80}$"
        },
        "journey_name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "url_or_route": {
          "type": "string",
          "minLength": 1
        },
        "page_type": {
          "type": "string",
          "minLength": 1
        },
        "expected_user_actions": {
          "$ref": "#/$defs/stringArray"
        },
        "business_goal": {
          "type": "string",
          "minLength": 1
        },
        "analysis_needs": {
          "$ref": "#/$defs/stringArray"
        },
        "success_signals": {
          "$ref": "#/$defs/stringArray"
        },
        "audience_or_segment_needs": {
          "$ref": "#/$defs/stringArray"
        },
        "data_available": {
          "$ref": "#/$defs/stringArray"
        },
        "implementation_context": {
          "$ref": "#/$defs/stringArray"
        },
        "constraints": {
          "$ref": "#/$defs/stringArray"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "open_questions": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "measurementStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detected_archetypes",
        "page_roles",
        "selected_event_families",
        "excluded_event_families",
        "custom_event_acceptance",
        "lead_event_model",
        "scalability_notes"
      ],
      "properties": {
        "detected_archetypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/detectedArchetype"
          }
        },
        "page_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pageRoleStrategy"
          }
        },
        "selected_event_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/selectedEventFamily"
          }
        },
        "excluded_event_families": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/excludedEventFamily"
          }
        },
        "custom_event_acceptance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/customEventAcceptance"
          }
        },
        "lead_event_model": {
          "$ref": "#/$defs/leadEventModel"
        },
        "scalability_notes": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "websiteCoverageMap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "site_scope",
        "coverage_summary",
        "sources_checked",
        "journeys_covered",
        "journeys_discovered",
        "coverage_gaps",
        "authenticated_journey",
        "playwright_recommendation"
      ],
      "properties": {
        "site_scope": {
          "enum": [
            "whole_site",
            "selected_journeys",
            "selected_pages",
            "single_journey",
            "template_only",
            "unknown"
          ]
        },
        "coverage_summary": {
          "type": "string",
          "minLength": 1
        },
        "sources_checked": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/coverageSource"
          }
        },
        "journeys_covered": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/journeyCoverage"
          }
        },
        "journeys_discovered": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/discoveredJourney"
          }
        },
        "coverage_gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/coverageGap"
          }
        },
        "authenticated_journey": {
          "$ref": "#/$defs/authenticatedJourney"
        },
        "playwright_recommendation": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason"
          ],
          "properties": {
            "status": {
              "enum": [
                "required",
                "recommended",
                "optional",
                "not_needed",
                "blocked"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "coverageSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_type",
        "source_ref",
        "used_for",
        "confidence"
      ],
      "properties": {
        "source_type": {
          "enum": [
            "sitemap",
            "robots_txt",
            "navigation",
            "url_list",
            "page_template",
            "static_html",
            "playwright_crawl",
            "browser_exploration",
            "synthetic_account_exploration",
            "existing_tracking_plan",
            "analytics_export",
            "search_console_export",
            "screenshots",
            "user_brief",
            "other"
          ]
        },
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "used_for": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        }
      }
    },
    "journeyCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journey_id",
        "journey_name",
        "representative_urls",
        "page_templates",
        "key_interactions",
        "coverage_status",
        "tracking_plan_decision",
        "evidence",
        "notes"
      ],
      "properties": {
        "journey_id": {
          "type": "string",
          "minLength": 1
        },
        "journey_name": {
          "type": "string",
          "minLength": 1
        },
        "representative_urls": {
          "$ref": "#/$defs/stringArray"
        },
        "page_templates": {
          "$ref": "#/$defs/stringArray"
        },
        "key_interactions": {
          "$ref": "#/$defs/stringArray"
        },
        "coverage_status": {
          "enum": [
            "covered",
            "partial",
            "assumed",
            "out_of_scope",
            "blocked"
          ]
        },
        "tracking_plan_decision": {
          "enum": [
            "included",
            "excluded",
            "needs_discovery"
          ]
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "discoveredJourney": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journey_id",
        "journey_name",
        "source_refs",
        "representative_urls",
        "page_templates",
        "key_interactions",
        "decision",
        "decision_reason"
      ],
      "properties": {
        "journey_id": {
          "type": "string",
          "minLength": 1
        },
        "journey_name": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "$ref": "#/$defs/stringArray"
        },
        "representative_urls": {
          "$ref": "#/$defs/stringArray"
        },
        "page_templates": {
          "$ref": "#/$defs/stringArray"
        },
        "key_interactions": {
          "$ref": "#/$defs/stringArray"
        },
        "decision": {
          "enum": [
            "include_in_plan",
            "exclude_low_value",
            "out_of_scope",
            "needs_discovery"
          ]
        },
        "decision_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "coverageGap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gap",
        "impact",
        "recommended_next_step"
      ],
      "properties": {
        "journey_id": {
          "type": "string"
        },
        "gap": {
          "type": "string",
          "minLength": 1
        },
        "impact": {
          "type": "string",
          "minLength": 1
        },
        "recommended_next_step": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "detectedArchetype": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archetype",
        "confidence",
        "evidence"
      ],
      "properties": {
        "archetype": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "pageRoleStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journey_id",
        "page_role",
        "business_purpose",
        "primary_success_signal"
      ],
      "properties": {
        "journey_id": {
          "type": "string",
          "minLength": 1
        },
        "page_role": {
          "type": "string",
          "minLength": 1
        },
        "business_purpose": {
          "type": "string",
          "minLength": 1
        },
        "primary_success_signal": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "selectedEventFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_id",
        "family_name",
        "events_or_actions",
        "reason",
        "official_sources_considered"
      ],
      "properties": {
        "family_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_\\-]{2,80}$"
        },
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "events_or_actions": {
          "$ref": "#/$defs/stringArray"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "official_sources_considered": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "excludedEventFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_name",
        "reason"
      ],
      "properties": {
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "customEventAcceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_name",
        "official_alternatives_considered",
        "business_reason",
        "required_parameters",
        "registration_notes"
      ],
      "properties": {
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "official_alternatives_considered": {
          "$ref": "#/$defs/stringArray"
        },
        "business_reason": {
          "type": "string",
          "minLength": 1
        },
        "required_parameters": {
          "$ref": "#/$defs/stringArray"
        },
        "registration_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "journey_id",
        "access_context",
        "event_name",
        "classification",
        "measurement_role",
        "business_event_family",
        "official_match",
        "official_verification",
        "page_url_pattern",
        "page_type",
        "page_or_component",
        "business_question",
        "trigger",
        "data_dependencies",
        "collection_strategy",
        "key_event",
        "priority",
        "parameters",
        "privacy",
        "analysis_use",
        "evidence_basis",
        "screenshot_coverage"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{2,80}$"
        },
        "journey_id": {
          "type": "string",
          "minLength": 1
        },
        "access_context": {
          "enum": [
            "public",
            "authentication_flow",
            "authenticated_area"
          ]
        },
        "event_name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.]{1,79}$"
        },
        "classification": {
          "enum": [
            "automatic",
            "enhanced_measurement",
            "recommended",
            "recommended_ecommerce",
            "custom"
          ]
        },
        "measurement_role": {
          "$ref": "#/$defs/measurementRole"
        },
        "business_event_family": {
          "type": "string",
          "minLength": 1
        },
        "official_match": {
          "type": "string",
          "minLength": 1
        },
        "official_verification": {
          "$ref": "#/$defs/officialVerification"
        },
        "page_url_pattern": {
          "type": "string",
          "minLength": 1
        },
        "page_type": {
          "type": "string",
          "minLength": 1
        },
        "page_or_component": {
          "type": "string",
          "minLength": 1
        },
        "business_question": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "data_dependencies": {
          "$ref": "#/$defs/stringArray"
        },
        "collection_strategy": {
          "$ref": "#/$defs/collectionStrategy"
        },
        "key_event": {
          "type": "boolean"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "parameters": {
          "$ref": "#/$defs/stringArray"
        },
        "data_layer": {
          "$ref": "#/$defs/dataLayer"
        },
        "ga4_payload": {
          "$ref": "#/$defs/ga4Payload"
        },
        "parameter_profile": {
          "$ref": "#/$defs/parameterProfile"
        },
        "privacy": {
          "$ref": "#/$defs/privacy"
        },
        "implementation_notes": {
          "type": "string"
        },
        "analysis_use": {
          "type": "string",
          "minLength": 1
        },
        "evidence_basis": {
          "$ref": "#/$defs/evidenceBasis"
        },
        "screenshot_coverage": {
          "$ref": "#/$defs/screenshotCoverage"
        }
      }
    },
    "officialVerification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "source_url",
        "checked_date",
        "scope_note"
      ],
      "properties": {
        "status": {
          "enum": [
            "verified",
            "unverified",
            "not_applicable"
          ]
        },
        "source_url": {
          "type": "string",
          "minLength": 1
        },
        "checked_date": {
          "type": "string",
          "format": "date"
        },
        "scope_note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "collectionStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "collection_source",
        "duplicate_risk"
      ],
      "properties": {
        "collection_source": {
          "enum": [
            "ga4_automatic",
            "ga4_enhanced_measurement",
            "manual_gtm",
            "data_layer",
            "gtag",
            "sdk",
            "server_side",
            "unknown"
          ]
        },
        "duplicate_risk": {
          "$ref": "#/$defs/duplicateRisk"
        }
      }
    },
    "duplicateRisk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "reason",
        "dedupe_rule"
      ],
      "properties": {
        "level": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "dedupe_rule": {
          "type": "string",
          "minLength": 1
        }
      }
    },
