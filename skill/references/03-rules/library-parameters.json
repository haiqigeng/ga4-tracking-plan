      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Video > video_duration"
    },
    {
      "parameter_name": "video_percent",
      "scope": "event",
      "type": "number",
      "required": "optional",
      "example": "50",
      "description": "The percentage of a video that a user watched.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Video > video_percent"
    },
    {
      "parameter_name": "video_provider",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "youtube",
      "description": "The source of an embedded video.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Video > video_provider"
    },
    {
      "parameter_name": "video_title",
      "scope": "event",
      "type": "string",
      "required": "optional",
