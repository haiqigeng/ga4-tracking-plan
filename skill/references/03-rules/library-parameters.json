{
  "scope": "Generic parameter proposition library for GA4 web tracking plans.",
  "policy": [
    "Use official GA4 parameters and item parameters when the event is official or ecommerce.",
    "Use custom parameters only when they answer a concrete analysis, segmentation, implementation, or optimization need.",
    "Use lowercase ASCII snake_case in the selected controlled-value language; multilingual websites use English and all values remove accents.",
    "Exhaust finite website values from browser or client evidence when practical and display them with space-pipe-space separators in human output.",
    "Do not use Universal Analytics fields such as eventCategory, eventAction, eventLabel, nonInteraction, dimension1, or metric1.",
    "Do not send PII, contact-derived identifiers, free text, account IDs, addresses, or sensitive user input to GA4. Governed non-GA4 implementation variables must identify destination, consent, transformation, and ownership."
  ],
  "official_parameter_definitions": [
    {
      "parameter_name": "page_location",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "https://www.example.com/products",
      "description": "The complete URL of the webpage that someone visited on your website.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Page / Screen > page_location"
    },
    {
      "parameter_name": "page_referrer",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "https://www.example.com/",
      "description": "The referring URL, which is the user's previous URL and can be your website's domain or other domains.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Page / Screen > page_referrer"
    },
    {
      "parameter_name": "page_title",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "Home",
      "description": "The HTML page title that you set on your website. The page_title parameter can override the title HTML tag.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Page / Screen > page_title"
    },
    {
      "parameter_name": "engagement_time_msec",
      "scope": "event",
      "type": "number",
      "required": "optional",
      "example": "1000",
      "description": "The amount of time a user spends with your web page in focus or app screen in the foreground.",
      "source_url": "https://support.google.com/analytics/answer/9234069?hl=en",
      "source_section": "Automatically collected events > engagement parameters"
    },
    {
      "parameter_name": "search_term",
      "scope": "event",
      "type": "string",
      "required": "required",
      "example": "t-shirts",
      "description": "The strings or keywords used in a search.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "General > search_term"
    },
    {
      "parameter_name": "link_classes",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "primary-link",
      "description": "The HTML class attribute for an outbound link or file download.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Link > link_classes"
    },
    {
      "parameter_name": "link_domain",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "example.com",
      "description": "The destination domain of an outbound link or file download.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Link > link_domain"
    },
    {
      "parameter_name": "link_id",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "primary-cta",
      "description": "The ID for an outbound link or file download.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Link > link_id"
    },
    {
      "parameter_name": "link_text",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "Download guide",
      "description": "The text of the link clicked by the user.",
      "source_url": "https://support.google.com/analytics/answer/9216061?hl=en",
      "source_section": "Events measurement and parameters > file_download"
    },
    {
      "parameter_name": "link_url",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "https://www.example.com/file.pdf",
      "description": "The full URL for an outbound link or file download.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Link > link_url"
    },
    {
      "parameter_name": "outbound",
      "scope": "event",
      "type": "boolean",
      "required": "optional",
      "example": "true",
      "description": "Indicates whether a click was on an outbound link.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "Link > outbound"
    },
    {
      "parameter_name": "file_extension",
