          "parameter_name": "items[].item_name",
          "display_name": "Item name",
          "scope": "item",
          "type": "string",
          "classification": "ga4_ecommerce_item_parameter",
          "value_rules": "Official readable item name. Each item needs item_id or item_name.",
          "registration_default": "not_needed_for_official_parameter"
        },
        {
          "parameter_name": "items[].item_brand",
          "display_name": "Item brand",
          "scope": "item",
          "type": "string",
