        },
        {
          "parameter_name": "items[].discount",
          "display_name": "Item discount",
          "scope": "item",
          "type": "number",
          "classification": "ga4_ecommerce_item_parameter",
          "value_rules": "Official item-level discount when available.",
          "registration_default": "not_needed_for_official_parameter"
        },
        {
          "parameter_name": "items[].index",
          "display_name": "Item index",
          "scope": "item",
          "type": "integer",
