      "source_section": "General > file_extension"
    },
    {
      "parameter_name": "file_name",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "guide.pdf",
      "description": "The page path of a file download.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "General > file_name"
    },
    {
      "parameter_name": "form_id",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "contact-form",
      "description": "The HTML id attribute of the form DOM element.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "General > form_id"
    },
    {
      "parameter_name": "form_name",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "contact",
      "description": "The HTML name attribute of the form element.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "General > form_name"
    },
    {
      "parameter_name": "form_destination",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "https://www.example.com/contact/submit",
      "description": "The URL to which the form is being submitted.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "General > form_destination"
    },
    {
      "parameter_name": "form_submit_text",
      "scope": "event",
      "type": "string",
      "required": "optional",
      "example": "Send",
      "description": "The text of the submit button, if present.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "General > form_submit_text"
    },
    {
      "parameter_name": "percent_scrolled",
      "scope": "event",
      "type": "number",
      "required": "optional",
      "example": "90",
      "description": "The percentage down the page that the user scrolled.",
      "source_url": "https://support.google.com/analytics/table/13594742?hl=en",
      "source_section": "General > percent_scrolled"
    },
    {
      "parameter_name": "video_current_time",
