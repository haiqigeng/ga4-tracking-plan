          "display_name": "Item price",
          "scope": "item",
          "type": "number",
          "classification": "ga4_ecommerce_item_parameter",
          "value_rules": "Official item unit price.",
          "registration_default": "not_needed_for_official_parameter"
        },
        {
          "parameter_name": "items[].quantity",
          "display_name": "Item quantity",
          "scope": "item",
          "type": "integer",
          "classification": "ga4_ecommerce_item_parameter",
