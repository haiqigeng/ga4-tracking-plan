  "families": [
    {
      "family": "global_page_context",
      "use_when": "Useful across page, content, form, support, and discovery events when values are stable and low-cardinality.",
      "parameters": [
        {
          "parameter_name": "page_type",
          "display_name": "Page type",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
          "value_rules": "Controlled lowercase ASCII snake_case, for example home | product_list | product_detail | cart | checkout | confirmation | content | support.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "page_template",
          "display_name": "Page template",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
          "value_rules": "Stable template key from CMS or frontend routing; avoid page titles or release-specific labels.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "journey_name",
          "display_name": "Journey name",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
          "value_rules": "Controlled business journey key, for example product_discovery | checkout | lead_form | account_access | support.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "journey_step",
          "display_name": "Journey step",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
          "value_rules": "Controlled step key, for example step_1 | shipping | payment | confirmation; do not include PII or raw form values.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "nav_language",
          "display_name": "Navigation language",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
          "value_rules": "Lowercase ISO 639-1 code observed from the website language selector or locale route, for example fr | en | de.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "nav_environment",
          "display_name": "Navigation environment",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
          "value_rules": "Controlled deployment environment supplied by the application configuration, for example production | staging | development.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "login_status",
          "display_name": "Login status",
          "scope": "user",
          "type": "string",
          "classification": "custom_user_property",
          "value_rules": "Controlled values: logged_in | logged_out. Update when authentication state changes; do not send account IDs.",
          "registration_default": "user_scoped_custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "customer_status",
          "display_name": "Customer status",
          "scope": "user",
          "type": "string",
          "classification": "custom_user_property",
          "value_rules": "Controlled values: new | returning | unknown from an approved backend rule.",
          "registration_default": "user_scoped_custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "account_type",
          "display_name": "Account type",
          "scope": "user",
          "type": "string",
          "classification": "custom_user_property",
          "value_rules": "Optional low-cardinality English account category; omit when the business has no stable account types.",
          "registration_default": "user_scoped_custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "user_id",
          "display_name": "GA4 User ID",
          "scope": "implementation",
          "type": "string",
          "classification": "implementation_variable",
          "value_rules": "Opaque stable non-PII ID. Map only to the Google tag user_id setting, omit until sign-in, set null on logout, and never register as a custom dimension.",
          "registration_default": "never_register_use_ga4_user_id_setting"
        }
      ]
    },
    {
      "family": "navigation",
      "use_when": "Header, menu, submenu, footer, and utility navigation events when the client uses surface-level event names.",
      "parameters": [
        {
          "parameter_name": "link_name",
          "display_name": "Link name",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
          "value_rules": "Stable English lowercase ASCII snake_case label derived from navigation purpose, not transient localized display text.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "link_url",
          "display_name": "Link URL",
          "scope": "event",
          "type": "string",
          "classification": "ga4_native_parameter",
          "value_rules": "Resolved destination URL after removing sensitive query parameters; do not translate URLs.",
          "registration_default": "not_needed_for_official_parameter"
        },
        {
          "parameter_name": "navigation_group",
          "display_name": "Navigation group",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
          "value_rules": "Controlled English group such as utility | primary | products | services | support | legal | social.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "navigation_level",
          "display_name": "Navigation level",
          "scope": "event",
          "type": "integer",
          "classification": "custom_event_parameter",
          "value_rules": "Positive menu depth such as 1 | 2 | 3; use only for nested menu navigation.",
          "registration_default": "custom_dimension_when_used_for_reporting"
        },
        {
          "parameter_name": "link_position",
          "display_name": "Link position",
          "scope": "event",
          "type": "integer",
          "classification": "custom_event_parameter",
          "value_rules": "One-based position within the relevant navigation group when stable and analytically useful.",
          "registration_default": "custom_dimension_only_if_stable"
        }
      ]
    },
    {
      "family": "component_and_content",
      "use_when": "Useful for select_content, navigation/content choices, contact intent, promotion context, and module analysis.",
      "parameters": [
        {
          "parameter_name": "component_type",
          "display_name": "Component type",
          "scope": "event",
          "type": "string",
          "classification": "custom_event_parameter",
