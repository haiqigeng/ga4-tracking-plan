        "event_key": "search",
        "flush_keys": [
          "event_data"
        ],
        "push": {
          "event": "search",
          "event_data": {
            "search_term": "%scrubbed_search_term%"
          }
        },
        "mapping_notes": "Send the official GA4 search_term parameter after PII scrubbing."
      },
      "ga4_payload": {
        "event_name": "search",
        "parameters": {
          "search_term": "%scrubbed_search_term%",
          "page_template": "homepage"
