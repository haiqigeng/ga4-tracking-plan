      "privacy": {
        "pii_risk": "medium",
        "consent_dependency": "analytics_storage",
        "cardinality_risk": "high",
        "notes": "Search terms can contain PII or high-cardinality data. Scrub email, phone, order IDs, and sensitive values before sending."
      },
