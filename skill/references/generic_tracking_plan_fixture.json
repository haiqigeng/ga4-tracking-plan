        "creative_name",
        "creative_slot",
        "items",
        "items[].item_id",
        "items[].item_name"
      ],
      "data_layer": {
        "event_key": "select_promotion",
        "flush_keys": [
          "ecommerce"
        ],
        "push": {
          "event": "select_promotion",
          "ecommerce": {
            "promotion_id": "%promotion_id%",
            "promotion_name": "%promotion_name%",
            "creative_name": "%creative_name%",
            "creative_slot": "%creative_slot%",
            "items": [
              {
                "item_id": "%promotion_item_id%",
                "item_name": "%promotion_item_name%"
              }
            ]
          }
        },
        "mapping_notes": "Use the same promotion identifiers as view_promotion for impression-to-click analysis."
      },
      "ga4_payload": {
        "event_name": "select_promotion",
        "parameters": {
          "promotion_id": "%promotion_id%",
          "promotion_name": "%promotion_name%",
          "creative_name": "%creative_name%",
          "creative_slot": "%creative_slot%"
        },
        "items": [
          {
            "item_id": "%promotion_item_id%",
            "item_name": "%promotion_item_name%"
          }
        ]
      },
      "privacy": {
        "pii_risk": "low",
        "consent_dependency": "analytics_storage",
        "cardinality_risk": "low",
        "notes": "Use stable controlled values; avoid visible text when it changes often."
      },
      "qa": {
        "qa_id": "QA-HOME-PROMO-SELECT",
        "methods": [
          "GTM Preview",
          "Network"
        ],
        "steps": [
          "Click a tracked homepage promotion."
        ],
        "expected_data_layer": [
          "ecommerce is flushed before the event.",
          "select_promotion uses the same promotion_id as the related view_promotion."
        ],
        "expected_network": [
          "GA4 request contains en=select_promotion.",
          "Promotion parameters and items are present."
        ],
        "debugview_expectation": "select_promotion appears after the user click.",
        "status": "not_started"
      },
      "implementation_notes": "Keep this as an ecommerce promotion event, not a generic click event."
    },
    {
      "event_id": "EVT-HOME-SEARCH",
      "journey_id": "homepage_discovery",
      "event_name": "search",
      "classification": "recommended",
      "official_ga4_match": "search",
      "page_url_pattern": "https://example.com/",
      "page_type": "homepage",
      "business_question": "What do users search for from the homepage?",
      "trigger": "User submits the site search form.",
      "key_event": false,
      "priority": "must",
      "parameters": [
        "search_term",
        "page_data.template"
