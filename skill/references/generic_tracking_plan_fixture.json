{
  "schema_version": "1.0.0",
  "plan_id": "generic_ecommerce_homepage",
  "document": {
    "title": "Generic GA4 ecommerce homepage tracking plan",
    "version": "v0.1",
    "status": "draft",
    "owner": "TBD",
    "created_date": "2026-06-26",
    "template_source": "assets/ga4_tracking_plan_template.xlsx",
    "notes": "Generic fixture for validating the skill contract, workbook generator, and QA-ready output."
  },
  "measurement_brief": [
    {
      "journey_id": "homepage_discovery",
      "journey_name": "Homepage discovery",
      "scope": "Single ecommerce homepage view and the primary discovery interactions visible on the page.",
      "url_or_route": "https://example.com/",
      "page_type": "homepage",
      "expected_user_actions": [
        "view homepage",
        "view merchandising promotions",
        "click a promotion",
        "submit site search",
        "select navigation or content module",
        "open account access"
      ],
      "business_goal": "Understand how the homepage supports product discovery, merchandising exposure, and account access intent.",
      "analysis_needs": [
        "Measure homepage traffic quality",
        "Compare promotion exposure and clicks",
        "Identify search usage and search themes",
        "Understand which modules or navigation areas drive deeper browsing"
      ],
      "success_signals": [
        "select_promotion",
        "search",
        "select_content",
        "account_access_intent"
      ],
      "audience_or_segment_needs": [
        "device category",
        "traffic source",
        "login status when available",
        "consent state"
      ],
      "data_available": [
        "page URL",
        "page title",
        "page template",
        "promotion metadata",
        "search term after PII scrubbing",
        "navigation/content metadata"
      ],
      "implementation_context": [
        "GTM web container",
        "dataLayer",
        "GA4 web stream"
      ],
      "constraints": [
        "Do not send direct PII",
        "Keep ecommerce promotion events in official GA4 ecommerce format",
        "Normalize controlled values to lowercase ASCII snake_case"
      ],
      "priority": "must",
      "open_questions": [
        "Confirm the final promotion metadata available in the CMS.",
        "Confirm whether account access should become a key event."
      ]
    }
  ],
  "events": [
    {
      "event_id": "EVT-HOME-PAGE-VIEW",
      "journey_id": "homepage_discovery",
      "event_name": "page_view",
      "classification": "automatic",
      "official_ga4_match": "page_view",
      "page_url_pattern": "https://example.com/",
      "page_type": "homepage",
      "business_question": "How many users view the homepage and from which acquisition contexts?",
      "trigger": "Homepage load or SPA route change to the homepage.",
      "key_event": false,
      "priority": "must",
      "parameters": [
        "page_location",
        "page_title",
        "page_referrer",
        "page_data.template"
      ],
      "data_layer": {
        "event_key": "page_view",
        "flush_keys": [
          "page_data"
        ],
        "push": {
          "event": "page_view",
          "page_data": {
            "location": "https://example.com/",
            "title": "%document_title%",
            "template": "homepage"
          }
        },
        "mapping_notes": "If GA4 automatic page_view is sufficient, do not duplicate it. Use manual page_view only for controlled SPA routing or enriched page context."
      },
      "ga4_payload": {
        "event_name": "page_view",
        "parameters": {
          "page_location": "%current_url%",
          "page_title": "%document_title%",
          "page_referrer": "%document_referrer%",
          "page_template": "homepage"
        },
        "items": []
      },
      "privacy": {
        "pii_risk": "low",
        "consent_dependency": "analytics_storage",
        "cardinality_risk": "medium",
        "notes": "Remove sensitive query parameters before sending page_location if the website can contain them."
      },
      "qa": {
        "qa_id": "QA-HOME-PAGE-VIEW",
        "methods": [
          "DebugView",
          "GTM Preview",
          "Network"
        ],
        "steps": [
          "Open https://example.com/ once.",
          "Reload only after the first test has been recorded."
        ],
        "expected_data_layer": [
          "page_data.location equals the current URL.",
          "page_data.template equals homepage."
        ],
        "expected_network": [
          "GA4 request contains en=page_view.",
          "page_location and page_title are populated."
        ],
        "debugview_expectation": "One homepage page_view appears for the initial load.",
        "status": "not_started"
      },
      "implementation_notes": "Avoid duplicate page_view if enhanced measurement already sends the correct event."
    },
    {
      "event_id": "EVT-HOME-PROMO-VIEW",
      "journey_id": "homepage_discovery",
      "event_name": "view_promotion",
      "classification": "recommended_ecommerce",
      "official_ga4_match": "view_promotion",
      "page_url_pattern": "https://example.com/",
      "page_type": "homepage",
      "business_question": "Which homepage promotions are exposed to users?",
      "trigger": "Promotion module is visible according to the agreed impression threshold.",
      "key_event": false,
      "priority": "should",
      "parameters": [
        "promotion_id",
        "promotion_name",
        "creative_name",
        "creative_slot",
        "items",
        "items[].item_id",
        "items[].item_name"
      ],
      "data_layer": {
        "event_key": "view_promotion",
        "flush_keys": [
          "ecommerce"
        ],
        "push": {
          "event": "view_promotion",
          "ecommerce": {
            "promotion_id": "%promotion_id%",
            "promotion_name": "%promotion_name%",
            "creative_name": "%creative_name%",
            "creative_slot": "%creative_slot%",
            "items": [
              {
                "item_id": "%promotion_item_id%",
                "item_name": "%promotion_item_name%"
              }
            ]
          }
        },
        "mapping_notes": "Rows in the tracking plan use official GA4 parameter names. ecommerce.* is only the GTM source object."
      },
      "ga4_payload": {
        "event_name": "view_promotion",
        "parameters": {
          "promotion_id": "%promotion_id%",
          "promotion_name": "%promotion_name%",
          "creative_name": "%creative_name%",
          "creative_slot": "%creative_slot%"
        },
        "items": [
          {
            "item_id": "%promotion_item_id%",
            "item_name": "%promotion_item_name%"
          }
        ]
      },
      "privacy": {
        "pii_risk": "low",
        "consent_dependency": "analytics_storage",
        "cardinality_risk": "low",
        "notes": "Promotion values should be controlled campaign or merchandising identifiers."
      },
      "qa": {
        "qa_id": "QA-HOME-PROMO-VIEW",
        "methods": [
          "GTM Preview",
          "Network"
        ],
        "steps": [
          "Open the homepage and expose a tracked promotion in the viewport."
        ],
        "expected_data_layer": [
          "ecommerce is flushed before the event.",
          "promotion_id, promotion_name, creative_name, creative_slot, and items are populated."
        ],
        "expected_network": [
          "GA4 request contains en=view_promotion.",
          "Promotion parameters and at least one valid item identifier are present."
        ],
        "debugview_expectation": "view_promotion appears once per qualified promotion impression.",
        "status": "not_started"
      },
      "implementation_notes": "Use one consolidated view_promotion definition and list allowed promotion values rather than one event per banner."
    },
    {
