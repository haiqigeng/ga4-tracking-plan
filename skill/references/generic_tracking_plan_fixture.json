        "qa_id": "QA-HOME-SEARCH",
        "methods": [
          "DebugView",
          "GTM Preview",
          "Network"
        ],
        "steps": [
          "Submit a safe test query such as summer_dress."
        ],
        "expected_data_layer": [
          "event_data.search_term is present.",
          "No direct PII is present in the pushed term."
        ],
        "expected_network": [
          "GA4 request contains en=search.",
          "search_term is populated."
        ],
        "debugview_expectation": "search appears with search_term.",
        "status": "not_started"
      },
      "implementation_notes": "Use the official recommended search event instead of a custom search_submit event."
