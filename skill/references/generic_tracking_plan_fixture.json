      "event_id": "EVT-HOME-ACCOUNT-ACCESS",
      "journey_id": "homepage_discovery",
      "event_name": "account_access_intent",
      "classification": "custom",
      "official_ga4_match": "no official GA4 event fits account entry intent before login",
      "page_url_pattern": "https://example.com/",
      "page_type": "homepage",
      "business_question": "How often do users try to access the account area from the homepage?",
      "trigger": "User clicks the account access entry point before the login result is known.",
      "key_event": false,
      "priority": "could",
      "parameters": [
        "cta_location",
        "cta_text",
        "login_status"
      ],
      "data_layer": {
        "event_key": "account_access_intent",
        "flush_keys": [
          "event_data"
        ],
        "push": {
          "event": "account_access_intent",
          "event_data": {
            "cta_location": "%cta_location%",
            "cta_text": "%normalized_cta_text%"
          },
          "user_data": {
            "login_status": "%login_status%"
          }
        },
        "mapping_notes": "Use the official login event only when a login actually succeeds."
      },
      "ga4_payload": {
        "event_name": "account_access_intent",
        "parameters": {
          "cta_location": "header | menu",
          "cta_text": "%normalized_cta_text%",
          "login_status": "logged | not_logged | unknown"
        },
        "items": []
      },
      "privacy": {
        "pii_risk": "low",
        "consent_dependency": "analytics_storage",
        "cardinality_risk": "low",
        "notes": "Do not send email, account ID, phone number, or customer number."
      },
      "qa": {
        "qa_id": "QA-HOME-ACCOUNT-ACCESS",
        "methods": [
          "GTM Preview",
          "Network"
        ],
        "steps": [
          "Click the account access entry point."
        ],
        "expected_data_layer": [
          "event_data.cta_location is populated.",
          "user_data.login_status is logged, not_logged, or unknown."
        ],
        "expected_network": [
          "GA4 request contains en=account_access_intent.",
          "No direct personal identifiers are present."
        ],
        "debugview_expectation": "account_access_intent appears only on account entry click, not on successful login.",
        "status": "not_started"
      },
      "implementation_notes": "This is custom because the official login event should represent successful authentication, not an account-link click."
    }
