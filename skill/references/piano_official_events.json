{
  "version": "2026-06-26",
  "scope": "Structured Piano Analytics event lookup for tracking-plan generation and review. Use with current official Piano documentation.",
  "source_priority": "Official Piano documentation first. This file is a cached routing aid, not a replacement for checking current docs when browsing is available.",
  "sources": [
    {
      "name": "Piano Analytics standard events",
      "type": "official",
      "url": "https://developers.piano.io/analytics/data-collection/how-to-send-events/standard-events/",
      "used_for": "Page, click, onsite ad, internal search, and MV testing event families."
    },
    {
      "name": "Piano Analytics Sales Insights",
      "type": "official",
      "url": "https://developers.piano.io/analytics/data-collection/how-to-send-events/sales-insights/",
      "used_for": "Product, cart, awaiting payment, transaction, and purchased-product events."
    },
    {
      "name": "Piano Analytics AV Insights",
      "type": "official",
      "url": "https://developers.piano.io/analytics/data-collection/how-to-send-events/av-insights/",
      "used_for": "Audio/video player events, heartbeat behavior, seek events, ad events, and player state events."
    },
    {
      "name": "Piano Analytics conversion",
      "type": "official",
      "url": "https://developers.piano.io/analytics/data-collection/how-to-send-events/conversion/",
      "used_for": "Conversion marking with goal_type."
    },
    {
      "name": "Piano Analytics Data Model properties",
      "type": "official",
      "url": "https://analytics-docs.piano.io/en/analytics/v1/properties",
      "used_for": "Property names, data types, and Data Model registration checks."
    }
  ],
  "event_families": [
    {
      "family": "page",
      "classification": "piano_standard",
      "use_for": "Page load, virtual page display, and page context measurement.",
      "events": [
        {
          "event": "page.display",
          "mandatory_properties": [],
          "core_properties": ["page", "page_chapter1", "page_chapter2", "page_chapter3"],
          "implementation": "pa.sendEvent('page.display', {...})"
        }
      ]
    },
    {
      "family": "click",
      "classification": "piano_standard",
      "use_for": "User clicks whose intent matters for analysis.",
      "events": [
        {
          "event": "click.action",
          "mandatory_properties": [],
          "core_properties": ["click", "click_chapter1", "click_chapter2", "click_chapter3"],
          "use_when": "The click performs an action on the current page or component."
        },
        {
          "event": "click.navigation",
          "mandatory_properties": [],
          "core_properties": ["click", "click_chapter1", "click_chapter2", "click_chapter3"],
          "use_when": "The click navigates inside the measured site or app."
        },
        {
          "event": "click.download",
          "mandatory_properties": [],
          "core_properties": ["click", "click_chapter1", "click_chapter2", "click_chapter3"],
          "use_when": "The click starts a downloadable asset."
        },
        {
          "event": "click.exit",
          "mandatory_properties": [],
          "core_properties": ["click", "click_chapter1", "click_chapter2", "click_chapter3"],
          "use_when": "The click exits to an external site."
        }
      ]
    },
    {
      "family": "onsite_ads",
      "classification": "piano_standard",
      "use_for": "Publisher ad and self-promotion impressions and clicks.",
      "events": [
        {
          "event": "publisher.impression",
          "mandatory_properties": ["onsitead_type"],
          "core_properties": ["onsitead_type", "onsitead_advertiser", "onsitead_campaign", "onsitead_category", "onsitead_creation", "onsitead_detailed_placement", "onsitead_format", "onsitead_general_placement", "onsitead_url", "onsitead_variant"]
        },
        {
          "event": "publisher.click",
          "mandatory_properties": ["onsitead_type"],
          "core_properties": ["onsitead_type", "onsitead_advertiser", "onsitead_campaign", "onsitead_category", "onsitead_creation", "onsitead_detailed_placement", "onsitead_format", "onsitead_general_placement", "onsitead_url", "onsitead_variant"]
        },
        {
          "event": "self_promotion.impression",
          "mandatory_properties": ["onsitead_type"],
          "core_properties": ["onsitead_type", "onsitead_campaign", "onsitead_category", "onsitead_creation", "onsitead_detailed_placement", "onsitead_format", "onsitead_general_placement", "onsitead_url", "onsitead_variant"]
        },
        {
          "event": "self_promotion.click",
          "mandatory_properties": ["onsitead_type"],
          "core_properties": ["onsitead_type", "onsitead_campaign", "onsitead_category", "onsitead_creation", "onsitead_detailed_placement", "onsitead_format", "onsitead_general_placement", "onsitead_url", "onsitead_variant"]
        }
      ]
    },
    {
      "family": "internal_search",
      "classification": "piano_standard",
      "use_for": "Internal search result display and result selection.",
      "events": [
        {
          "event": "internal_search_result.display",
          "mandatory_properties": [],
          "core_properties": ["ise_keyword", "ise_page"]
        },
        {
          "event": "internal_search_result.click",
          "mandatory_properties": [],
          "core_properties": ["ise_keyword", "ise_click_rank", "ise_page"]
        }
      ]
    },
    {
      "family": "mv_testing",
      "classification": "piano_standard",
      "use_for": "Multivariate test exposure and click measurement.",
      "events": [
        {
          "event": "mv_test.display",
          "mandatory_properties": [],
          "core_properties": ["mv_creation", "mv_test", "mv_wave"]
        },
        {
          "event": "mv_test.click",
          "mandatory_properties": [],
          "core_properties": ["mv_creation", "mv_test", "mv_wave"]
        }
      ]
    },
    {
      "family": "sales_insights_product",
      "classification": "piano_sales_insights",
      "use_for": "Product impressions, product page displays, cart additions, cart removals, and purchased products.",
      "events": [
        {
          "event": "product.display",
          "mandatory_properties": ["product_id"],
          "core_properties": ["product_id", "product", "product_variant", "product_brand", "product_discount", "product_placement", "product_pricetaxincluded", "product_pricetaxfree", "product_stock", "product_category1", "product_category2", "product_category3", "product_category4"]
        },
        {
          "event": "product.page_display",
          "mandatory_properties": ["product_id"],
          "core_properties": ["product_id", "product", "product_variant", "product_brand", "product_discount", "product_pricetaxincluded", "product_pricetaxfree", "product_stock", "product_category1", "product_category2", "product_category3", "product_category4"]
        },
        {
          "event": "product.add_to_cart",
          "mandatory_properties": ["product_id"],
          "core_properties": ["cart_id", "product_id", "product", "product_variant", "product_brand", "product_discount", "product_placement", "product_pricetaxincluded", "product_pricetaxfree", "product_stock", "product_category1", "product_category2", "product_category3", "product_category4", "product_quantity", "product_cartcreation"],
          "bundle_note": "Emit cart.creation as a second event when product.add_to_cart creates a new cart."
        },
        {
          "event": "product.remove_from_cart",
          "mandatory_properties": ["product_id"],
          "core_properties": ["cart_id", "product_id", "product", "product_variant", "product_brand", "product_discount", "product_placement", "product_pricetaxincluded", "product_pricetaxfree", "product_stock", "product_category1", "product_category2", "product_category3", "product_category4", "product_quantity"]
        },
        {
          "event": "product.awaiting_payment",
          "mandatory_properties": ["cart_id", "cart_version", "product_id"],
          "core_properties": ["cart_id", "cart_version", "product_id", "product", "product_variant", "product_brand", "product_discount", "product_placement", "product_pricetaxincluded", "product_pricetaxfree", "product_stock", "product_category1", "product_category2", "product_category3", "product_category4", "product_quantity"]
        },
        {
          "event": "product.purchased",
          "mandatory_properties": ["product_id", "transaction_id"],
          "core_properties": ["cart_id", "transaction_id", "product_id", "product", "product_variant", "product_brand", "product_discount", "product_placement", "product_pricetaxincluded", "product_pricetaxfree", "product_stock", "product_category1", "product_category2", "product_category3", "product_category4", "product_quantity"]
        }
      ]
    },
    {
      "family": "sales_insights_cart",
      "classification": "piano_sales_insights",
      "use_for": "Cart creation, display, update, delivery, payment, and awaiting-payment funnel steps.",
      "events": [
        {
          "event": "cart.creation",
          "mandatory_properties": ["cart_id"],
          "core_properties": ["cart_id", "cart_currency", "cart_turnovertaxincluded", "cart_turnovertaxfree", "cart_quantity", "cart_nbdistinctproduct"]
        },
        {
          "event": "cart.display",
          "mandatory_properties": ["cart_id"],
          "core_properties": ["cart_id", "cart_currency", "cart_turnovertaxincluded", "cart_turnovertaxfree", "cart_quantity", "cart_nbdistinctproduct"]
        },
        {
          "event": "cart.update",
          "mandatory_properties": ["cart_id"],
          "core_properties": ["cart_id", "cart_currency", "cart_turnovertaxincluded", "cart_turnovertaxfree", "cart_quantity", "cart_nbdistinctproduct"]
        },
        {
          "event": "cart.delivery",
          "mandatory_properties": ["cart_id"],
          "core_properties": ["cart_id", "cart_currency", "cart_turnovertaxincluded", "cart_turnovertaxfree", "cart_quantity", "cart_nbdistinctproduct", "shipping_delivery", "shipping_costtaxincluded", "shipping_costtaxfree"]
        },
        {
          "event": "cart.payment",
          "mandatory_properties": ["cart_id"],
          "core_properties": ["cart_id", "cart_currency", "cart_turnovertaxincluded", "cart_turnovertaxfree", "cart_quantity", "cart_nbdistinctproduct", "shipping_delivery", "shipping_costtaxincluded", "shipping_costtaxfree", "payment_mode"]
        },
        {
          "event": "cart.awaiting_payment",
          "mandatory_properties": ["cart_id", "cart_version"],
          "core_properties": ["cart_id", "cart_version", "cart_currency", "cart_creation_utc", "cart_turnovertaxincluded", "cart_turnovertaxfree", "cart_quantity", "cart_nbdistinctproduct", "shipping_delivery", "shipping_costtaxincluded", "shipping_costtaxfree"]
        }
      ]
    },
    {
      "family": "sales_insights_transaction",
      "classification": "piano_sales_insights",
      "use_for": "Transaction confirmation and delayed server-side transaction confirmation.",
      "events": [
        {
          "event": "transaction.confirmation",
          "mandatory_properties": ["transaction_id"],
          "core_properties": ["cart_id", "cart_currency", "cart_turnovertaxincluded", "cart_creation_utc", "cart_turnovertaxfree", "cart_quantity", "cart_nbdistinctproduct", "shipping_delivery", "shipping_costtaxincluded", "shipping_costtaxfree", "transaction_id", "transaction_promocode", "transaction_status", "transaction_firstpurchase", "payment_mode"],
          "server_side_extra_mandatory_properties": ["cart_id", "offsite_confirmation"]
        }
      ]
    },
    {
      "family": "av_insights",
      "classification": "piano_av_insights",
      "use_for": "Audio/video media display, playback, heartbeat, seeking, ad, and player state events.",
      "events": [
        {"event": "av.play", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.buffer.start", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.buffer.heartbeat", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.start", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.heartbeat", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.pause", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.rebuffer.start", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.rebuffer.heartbeat", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.resume", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.stop", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.seek.start", "mandatory_properties": [], "core_properties": ["av_position"]},
        {"event": "av.forward", "mandatory_properties": [], "core_properties": ["av_previous_position", "av_position"]},
        {"event": "av.backward", "mandatory_properties": [], "core_properties": ["av_previous_position", "av_position"]},
        {"event": "av.ad.click", "mandatory_properties": [], "core_properties": []},
        {"event": "av.ad.skip", "mandatory_properties": [], "core_properties": []},
        {"event": "av.error", "mandatory_properties": [], "core_properties": ["av_player_error"]},
        {"event": "av.display", "mandatory_properties": [], "core_properties": []},
        {"event": "av.close", "mandatory_properties": [], "core_properties": []},
        {"event": "av.volume", "mandatory_properties": [], "core_properties": []},
        {"event": "av.subtitle.on", "mandatory_properties": [], "core_properties": []},
        {"event": "av.subtitle.off", "mandatory_properties": [], "core_properties": []},
        {"event": "av.fullscreen.on", "mandatory_properties": [], "core_properties": []},
        {"event": "av.fullscreen.off", "mandatory_properties": [], "core_properties": []},
        {"event": "av.quality", "mandatory_properties": [], "core_properties": []},
        {"event": "av.speed", "mandatory_properties": [], "core_properties": []},
        {"event": "av.share", "mandatory_properties": [], "core_properties": []}
      ]
    }
  ],
  "scenario_mappings": [
    {
      "business_scenario": "page_view_or_virtual_page",
      "ga4_event": "page_view",
      "piano_event": "page.display",
      "notes": "Keep page URL/title behavior platform-specific. Piano expects page and chapter properties; GA4 uses page_location, page_title, and related page parameters."
    },
    {
      "business_scenario": "internal_navigation_click",
      "ga4_event": "select_content",
      "piano_event": "click.navigation",
      "notes": "Use a click/navigation event in Piano, not a GA4 select_content clone."
    },
    {
      "business_scenario": "onsite_search_result_display",
      "ga4_event": "search or view_search_results",
      "piano_event": "internal_search_result.display",
      "notes": "Scrub search terms for PII before sending to either platform."
    },
    {
      "business_scenario": "product_impression",
      "ga4_event": "view_item_list",
      "piano_event": "product.display",
      "notes": "Use GA4 items arrays for GA4 and Piano product properties for Piano."
    },
    {
      "business_scenario": "product_detail_view",
      "ga4_event": "view_item",
      "piano_event": "product.page_display",
      "notes": "Do not use GA4 item parameter names as Piano properties."
    },
    {
      "business_scenario": "add_to_cart",
      "ga4_event": "add_to_cart",
      "piano_event": "product.add_to_cart",
      "notes": "For Piano, bundle cart.creation only when the add-to-cart action creates a new cart."
    },
    {
      "business_scenario": "checkout_delivery_or_shipping",
      "ga4_event": "add_shipping_info",
      "piano_event": "cart.delivery",
      "notes": "GA4 uses shipping_tier; Piano uses cart and shipping properties such as shipping_delivery and shipping costs."
    },
    {
      "business_scenario": "checkout_payment",
      "ga4_event": "add_payment_info",
      "piano_event": "cart.payment",
      "notes": "GA4 uses payment_type; Piano uses payment_mode with cart properties."
    },
    {
      "business_scenario": "purchase_confirmation",
      "ga4_event": "purchase",
      "piano_event": "transaction.confirmation plus product.purchased",
      "notes": "Piano transaction confirmation and purchased-product events may be emitted as a bundle; keep mandatory properties visible for each event."
    },
    {
      "business_scenario": "video_playback",
      "ga4_event": "video_start, video_progress, video_complete when enhanced measurement supports the player",
      "piano_event": "av.play, av.start, av.heartbeat, av.pause, av.stop, and related AV Insights events",
      "notes": "Use platform-native media models instead of custom media events when official support fits."
    }
  ]
}
