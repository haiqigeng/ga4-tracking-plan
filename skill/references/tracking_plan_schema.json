{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HQ-Guillaume/ga4-tracking-plan/schema/tracking_plan_schema.json",
  "title": "Analytics tracking plan contract",
  "description": "Canonical machine-readable structure for tracking plans produced by the skill. GA4 remains the default platform, with optional platform mappings for Piano Analytics and later QA automation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "plan_id",
    "analytics_platforms",
    "document",
    "measurement_brief",
    "measurement_strategy",
    "events",
    "parameters",
    "custom_definitions",
    "key_events",
    "not_tracked",
    "assumptions",
    "documentation_sources_checked",
    "qa_cases"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]{2,80}$"
    },
    "analytics_platforms": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analyticsPlatform"
      },
      "uniqueItems": true
    },
    "document": {
      "$ref": "#/$defs/document"
    },
    "measurement_brief": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/measurementBrief"
      }
    },
    "measurement_strategy": {
      "$ref": "#/$defs/measurementStrategy"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/event"
      }
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "custom_definitions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/customDefinition"
      }
    },
    "key_events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/keyEvent"
      }
    },
    "not_tracked": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/notTracked"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "documentation_sources_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/documentationSource"
      }
    },
    "qa_cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/qaCase"
      }
    }
  },
  "$defs": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "version",
        "status",
        "owner",
        "created_date",
        "template_source"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "draft",
            "ready_for_review",
            "approved",
            "deprecated"
          ]
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "created_date": {
          "type": "string",
          "format": "date"
        },
        "template_source": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "measurementBrief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journey_id",
        "journey_name",
        "scope",
        "url_or_route",
        "page_type",
        "expected_user_actions",
        "business_goal",
        "analysis_needs",
        "success_signals",
        "data_available",
        "implementation_context",
        "priority",
        "open_questions"
      ],
      "properties": {
        "journey_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_\\-]{2,80}$"
        },
        "journey_name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "url_or_route": {
          "type": "string",
          "minLength": 1
        },
        "page_type": {
          "type": "string",
          "minLength": 1
        },
        "expected_user_actions": {
          "$ref": "#/$defs/stringArray"
        },
        "business_goal": {
          "type": "string",
          "minLength": 1
        },
        "analysis_needs": {
          "$ref": "#/$defs/stringArray"
        },
        "success_signals": {
          "$ref": "#/$defs/stringArray"
        },
        "audience_or_segment_needs": {
          "$ref": "#/$defs/stringArray"
        },
        "data_available": {
          "$ref": "#/$defs/stringArray"
        },
        "implementation_context": {
          "$ref": "#/$defs/stringArray"
        },
        "constraints": {
          "$ref": "#/$defs/stringArray"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "open_questions": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "measurementStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detected_archetypes",
        "page_roles",
        "selected_event_families",
        "excluded_event_families",
        "custom_event_acceptance"
      ],
      "properties": {
        "detected_archetypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/detectedArchetype"
          }
        },
        "page_roles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/pageRoleStrategy"
          }
        },
        "selected_event_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/selectedEventFamily"
          }
        },
        "excluded_event_families": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/excludedEventFamily"
          }
        },
        "custom_event_acceptance": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/customEventAcceptance"
          }
        }
      }
    },
    "detectedArchetype": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "archetype",
        "confidence",
        "evidence"
      ],
      "properties": {
        "archetype": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "evidence": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "pageRoleStrategy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "journey_id",
        "page_role",
        "business_purpose",
        "primary_success_signal"
      ],
      "properties": {
        "journey_id": {
          "type": "string",
          "minLength": 1
        },
        "page_role": {
          "type": "string",
          "minLength": 1
        },
        "business_purpose": {
          "type": "string",
          "minLength": 1
        },
        "primary_success_signal": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "selectedEventFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_id",
        "family_name",
        "analytics_platform",
        "events_or_actions",
        "reason",
        "official_sources_considered"
      ],
      "properties": {
        "family_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_\\-]{2,80}$"
        },
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "analytics_platform": {
          "$ref": "#/$defs/analyticsPlatform"
        },
        "events_or_actions": {
          "$ref": "#/$defs/stringArray"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "official_sources_considered": {
          "$ref": "#/$defs/stringArray"
        }
      }
    },
    "excludedEventFamily": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "family_name",
        "reason"
      ],
      "properties": {
        "family_name": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "customEventAcceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_name",
        "official_alternatives_considered",
        "business_reason",
        "required_parameters",
        "registration_notes"
      ],
      "properties": {
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "official_alternatives_considered": {
          "$ref": "#/$defs/stringArray"
        },
        "business_reason": {
          "type": "string",
          "minLength": 1
        },
        "required_parameters": {
          "$ref": "#/$defs/stringArray"
        },
        "registration_notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "journey_id",
        "event_name",
        "classification",
        "measurement_role",
        "business_event_family",
        "primary_platform",
        "official_match",
        "page_url_pattern",
        "page_type",
        "page_or_component",
        "business_question",
        "trigger",
        "data_dependencies",
        "key_event",
        "priority",
        "parameters",
        "privacy",
        "qa"
      ],
      "properties": {
        "event_id": {
          "type": "string",
          "pattern": "^[A-Z0-9][A-Z0-9_\\-]{2,80}$"
        },
        "journey_id": {
          "type": "string",
          "minLength": 1
        },
        "event_name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.]{1,79}$"
        },
        "classification": {
          "enum": [
            "automatic",
            "enhanced_measurement",
            "recommended",
            "recommended_ecommerce",
            "custom",
            "piano_standard",
            "piano_sales_insights",
            "piano_av_insights",
            "piano_custom"
          ]
        },
        "measurement_role": {
          "$ref": "#/$defs/measurementRole"
        },
        "business_event_family": {
          "type": "string",
          "minLength": 1
        },
        "primary_platform": {
          "$ref": "#/$defs/analyticsPlatform"
        },
        "official_match": {
          "type": "string",
          "minLength": 1
        },
        "official_ga4_match": {
          "type": "string",
          "minLength": 1
        },
        "page_url_pattern": {
          "type": "string",
          "minLength": 1
        },
        "page_type": {
          "type": "string",
          "minLength": 1
        },
        "page_or_component": {
          "type": "string",
          "minLength": 1
        },
        "business_question": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "data_dependencies": {
          "$ref": "#/$defs/stringArray"
        },
        "key_event": {
          "type": "boolean"
        },
        "priority": {
          "$ref": "#/$defs/priority"
        },
        "parameters": {
          "$ref": "#/$defs/stringArray"
        },
        "data_layer": {
          "$ref": "#/$defs/dataLayer"
        },
        "ga4_payload": {
          "$ref": "#/$defs/ga4Payload"
        },
        "platform_mappings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/platformMapping"
          }
        },
        "implementation_payloads": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/implementationPayload"
          }
        },
        "privacy": {
          "$ref": "#/$defs/privacy"
        },
        "qa": {
          "$ref": "#/$defs/qa"
        },
        "implementation_notes": {
          "type": "string"
        }
      }
    },
    "dataLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_key",
        "flush_keys",
        "push"
      ],
      "properties": {
        "event_key": {
          "type": "string"
        },
        "flush_keys": {
          "$ref": "#/$defs/stringArray"
        },
        "push": {
          "type": "object",
          "additionalProperties": true
        },
        "mapping_notes": {
          "type": "string"
        }
      }
    },
    "ga4Payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_name",
        "parameters",
        "items"
      ],
      "properties": {
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/anyJsonValue"
          }
        },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/$defs/anyJsonValue"
            }
          }
        }
      }
    },
    "platformMapping": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "event_name",
        "classification",
        "official_match",
        "parameters_or_properties",
        "implementation_notes",
        "documentation_source"
      ],
      "properties": {
        "platform": {
          "$ref": "#/$defs/analyticsPlatform"
        },
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "type": "string",
          "minLength": 1
        },
        "official_match": {
          "type": "string",
          "minLength": 1
        },
        "parameters_or_properties": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/anyJsonValue"
          }
        },
        "items_or_products": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/$defs/anyJsonValue"
            }
          }
        },
        "implementation_notes": {
          "type": "string"
        },
        "documentation_source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "implementationPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "method",
        "event_name",
        "payload",
        "notes"
      ],
      "properties": {
        "platform": {
          "$ref": "#/$defs/analyticsPlatform"
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/anyJsonValue"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pii_risk",
        "consent_dependency",
        "cardinality_risk",
        "notes"
      ],
      "properties": {
        "pii_risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "consent_dependency": {
          "type": "string",
          "minLength": 1
        },
        "cardinality_risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "qa": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qa_id",
        "methods",
        "steps",
        "expected_data_layer",
        "expected_network",
        "debugview_expectation",
        "status"
      ],
      "properties": {
        "qa_id": {
          "type": "string",
          "pattern": "^QA-[A-Z0-9_\\-]{2,80}$"
        },
        "methods": {
          "$ref": "#/$defs/stringArray"
        },
        "steps": {
          "$ref": "#/$defs/stringArray"
        },
        "expected_data_layer": {
          "$ref": "#/$defs/stringArray"
        },
        "expected_network": {
          "$ref": "#/$defs/stringArray"
        },
        "debugview_expectation": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/qaStatus"
        }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter_name",
        "display_name",
        "scope",
        "type",
        "classification",
        "required",
        "description",
        "reporting_purpose",
        "value_rules",
        "example_value",
        "allowed_values",
        "source",
        "register_custom_definition",
        "cardinality_risk",
        "pii_risk",
        "consent_dependency"
      ],
      "properties": {
        "parameter_name": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "enum": [
            "event",
            "item",
            "user",
            "implementation"
          ]
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "classification": {
          "$ref": "#/$defs/parameterClassification"
        },
        "required": {
          "enum": [
            "required",
            "conditional",
            "optional"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "reporting_purpose": {
          "type": "string",
          "minLength": 1
        },
        "value_rules": {
          "type": "string",
          "minLength": 1
        },
        "example_value": {
          "type": "string"
        },
        "allowed_values": {
          "$ref": "#/$defs/stringArray"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "register_custom_definition": {
          "type": "boolean"
        },
        "cardinality_risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "pii_risk": {
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "consent_dependency": {
          "type": "string"
        }
      }
    },
    "customDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parameter_name",
        "display_name",
        "scope",
        "registration_type",
        "reason",
        "priority"
      ],
      "properties": {
        "parameter_name": {
          "type": "string",
          "minLength": 1
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "enum": [
            "event",
            "item",
            "user"
          ]
        },
        "registration_type": {
          "enum": [
            "custom_dimension",
            "custom_metric",
            "user_property",
            "piano_data_model_property"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "$ref": "#/$defs/priority"
        }
      }
    },
    "keyEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_name",
        "reason",
        "conditions"
      ],
      "properties": {
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "conditions": {
          "type": "string"
        }
      }
    },
    "notTracked": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interaction",
        "reason"
      ],
      "properties": {
        "interaction": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "documentationSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "url",
        "source_type",
        "checked_for"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "enum": [
            "official",
            "trusted_practitioner",
            "client_template",
            "internal"
          ]
        },
        "checked_for": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "qaCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "qa_id",
        "event_id",
        "event_name",
        "methods",
        "steps",
        "expected_data_layer",
        "expected_network",
        "debugview_expectation",
        "status",
        "evidence"
      ],
      "properties": {
        "qa_id": {
          "type": "string",
          "pattern": "^QA-[A-Z0-9_\\-]{2,80}$"
        },
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "event_name": {
          "type": "string",
          "minLength": 1
        },
        "methods": {
          "$ref": "#/$defs/stringArray"
        },
        "steps": {
          "$ref": "#/$defs/stringArray"
        },
        "expected_data_layer": {
          "$ref": "#/$defs/stringArray"
        },
        "expected_network": {
          "$ref": "#/$defs/stringArray"
        },
        "debugview_expectation": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "$ref": "#/$defs/qaStatus"
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "priority": {
      "enum": [
        "must",
        "should",
        "could"
      ]
    },
    "measurementRole": {
      "enum": [
        "macro_conversion",
        "micro_conversion",
        "diagnostic",
        "context"
      ]
    },
    "qaStatus": {
      "enum": [
        "not_started",
        "OK",
        "KO",
        "Cannot test"
      ]
    },
    "analyticsPlatform": {
      "enum": [
        "ga4",
        "piano_analytics",
        "other"
      ]
    },
    "parameterClassification": {
      "enum": [
        "ga4_auto_collected_parameter",
        "ga4_native_parameter",
        "ga4_recommended_parameter",
        "ga4_ecommerce_parameter",
        "ga4_ecommerce_item_parameter",
        "custom_event_parameter",
        "custom_user_property",
        "gtm_builtin_variable",
        "data_layer_variable",
